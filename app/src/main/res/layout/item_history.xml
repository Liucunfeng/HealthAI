<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- 顶部信息行：时间·档案名（左）、类型、删除按钮（右） -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_meta"
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tv_type"
            android:textSize="12sp"
            android:paddingEnd="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btn_delete"
            style="?attr/materialButtonOutlinedStyle"
            android:text="@string/history_delete"
            android:textSize="12sp"
            android:minHeight="32dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- 四张缩略图：等宽填充整行，比例放大（centerCrop）；不足四张显示纯白色块占位 -->
    <LinearLayout
        android:id="@+id/ll_thumbs"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <ImageView
            android:id="@+id/iv_thumb_0"
            android:layout_width="0dp"
            android:layout_height="130dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:scaleType="centerCrop"
            android:background="@android:color/white" />

        <ImageView
            android:id="@+id/iv_thumb_1"
            android:layout_width="0dp"
            android:layout_height="130dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:scaleType="centerCrop"
            android:background="@android:color/white" />

        <ImageView
            android:id="@+id/iv_thumb_2"
            android:layout_width="0dp"
            android:layout_height="130dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:scaleType="centerCrop"
            android:background="@android:color/white" />

        <ImageView
            android:id="@+id/iv_thumb_3"
            android:layout_width="0dp"
            android:layout_height="130dp"
            android:layout_weight="1"
            android:scaleType="centerCrop"
            android:background="@android:color/white" />
    </LinearLayout>

    <!-- 文字分析结果：移到四图下方一行，顶格左对齐（与缩略图同左缘，无额外缩进） -->
    <TextView
        android:id="@+id/tv_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="14sp" />
</LinearLayout>
